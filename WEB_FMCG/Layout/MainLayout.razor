
 @namespace WEB_FMCG.Pages
 @inherits LayoutComponentBase


<div class="flex h-screen w-full bg-[#F8FAFC] overflow-hidden font-sans">
    
    <aside class="flex-shrink-0 relative z-20">
        <SideBar />
    </aside>

    <main class="flex-1 flex flex-col min-w-0 relative overflow-hidden">
        
        <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200/60 flex items-center px-10 justify-between sticky top-0 z-10">
            <div class="flex flex-col">
                <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">
                    <span class="hover:text-indigo-600 cursor-pointer transition-colors">Platform</span>
                    <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-600">@GetActivePageName()</span>
                </div>
                <h1 class="text-xl font-black text-slate-900 tracking-tight mt-0.5">@GetActivePageName() <span class="text-indigo-600">.</span></h1>
            </div>

            <div class="flex items-center gap-6">
                <div class="hidden md:flex items-center bg-slate-100 rounded-2xl px-4 py-2 border border-transparent focus-within:border-indigo-300 focus-within:bg-white transition-all w-64">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" placeholder="Quick Search..." class="bg-transparent border-none text-xs font-bold ml-2 focus:ring-0 text-slate-600 placeholder:text-slate-400 w-full" />
                </div>

                <button class="relative w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 hover:text-indigo-600 hover:border-indigo-200 hover:shadow-lg hover:shadow-indigo-500/10 transition-all group">
                    <svg class="w-5 h-5 group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                </button>

                <div class="h-8 w-[1px] bg-slate-200"></div>

                <div class="hidden lg:flex flex-col items-end">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Today</p>
                    <p class="text-xs font-bold text-slate-700">@DateTime.Now.ToString("dd MMM yyyy")</p>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto custom-scrollbar relative">
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-500/5 blur-[120px] rounded-full -z-10"></div>
            <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-blue-500/5 blur-[100px] rounded-full -z-10"></div>

            <div class="p-10">
                <div class="max-w-[1600px] mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700 ease-out">
                    @Body
                </div>
            </div>

            <footer class="px-10 py-6 border-t border-slate-200/60 flex justify-between items-center bg-white/50">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">© @DateTime.Now.Year FMCG Pro System • Enterprise Edition</p>
                <div class="flex gap-4">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest italic">System Online</p>
                </div>
            </footer>
        </div>

    </main>
</div>

@code {
    // Logic sederhana untuk mengambil nama halaman aktif
    private string GetActivePageName()
    {
        // Anda bisa mengintegrasikan NavigationManager di sini
        return "Dashboard Overview"; 
    }
}

<style>
    /* Premium Scrollbar */
    .custom-scrollbar::-webkit-scrollbar { width: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { 
        background: #E2E8F0; 
        border-radius: 20px; 
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #CBD5E1; }

    /* Shimmer Effect for Profile */
    @@keyframes shimmer {
        100% { transform: translateX(100%); }
    }
    .animate-shimmer {
        animation: shimmer 2s infinite;
    }
</style>