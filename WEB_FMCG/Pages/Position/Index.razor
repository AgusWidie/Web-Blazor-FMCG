@page "/position"
@using WEB_FMCG.Help
@using WEB_FMCG.Services
@using WEB_FMCG.Models
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject IDivisionService _divisionService
@inject IPositionService _positionService

<style>
    .pos-page::-webkit-scrollbar { width: 5px; height: 5px; }
    .pos-page::-webkit-scrollbar-track { background: transparent; }
    .pos-page::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
    .glass {
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 4px 24px rgba(15,23,42,0.05);
    }
    .pos-page tbody tr { transition: all 0.18s ease; }
    .pos-page tbody tr:hover {
        background: linear-gradient(135deg, #eef2ff 0%, #e8e0ff 100%);
        box-shadow: inset 3px 0 0 #818cf8;
    }
    .btn-shine { position: relative; overflow: hidden; }
    .btn-shine::after {
        content: ''; position: absolute; top: -50%; left: -60%;
        width: 40%; height: 200%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: skewX(-20deg); transition: left 0.5s ease;
    }
    .btn-shine:hover::after { left: 120%; }
    .field:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 3px rgba(129,140,248,0.1);
    }
    .dot-bg {
        background-image: radial-gradient(circle, #e2e8f0 0.8px, transparent 0.8px);
        background-size: 22px 22px;
    }
    .stat-card { transition: all 0.2s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(15,23,42,0.07); }
    .orb-a {
        position: fixed; width: 380px; height: 380px; border-radius: 50%;
        background: radial-gradient(circle, rgba(129,140,248,0.07), transparent 70%);
        top: -90px; right: -90px; pointer-events: none;
    }
    .orb-b {
        position: fixed; width: 320px; height: 320px; border-radius: 50%;
        background: radial-gradient(circle, rgba(168,85,247,0.05), transparent 70%);
        bottom: -70px; left: -70px; pointer-events: none;
    }
    .page-btn { transition: all 0.15s ease; }
    .page-btn:not(:disabled):hover {
        background: #818cf8; color: white; border-color: #818cf8; transform: scale(1.05);
    }
    .page-btn:not(:disabled):active { transform: scale(0.97); }
    
    .modal-overlay {
        transition: opacity 0.2s ease;
    }
    .modal-box {
        animation: modalIn 0.25s ease-out;
    }
    @@keyframes modalIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
</style>

<div class="pos-page relative min-h-screen bg-gradient-to-br from-slate-50 via-indigo-50/30 to-violet-50/20 text-gray-900 font-sans">

    <div class="orb-a"></div>
    <div class="orb-b"></div>
    <div class="dot-bg absolute inset-0 opacity-35 pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto p-6 lg:p-10 space-y-7">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sky-500 to-blue-500 flex items-center justify-center shadow-sm shadow-sky-200/50">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-semibold text-sky-600 uppercase tracking-widest">Organization</span>
                </div>
                <h1 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">Position Management</h1>
                <p class="text-sm text-slate-400">Kelola data master posisi jabatan karyawan</p>
            </div>

            <div class="flex items-center gap-2.5">
                <button @onclick="ExportExcel"
                        class="flex items-center gap-2 px-5 py-2.5 text-sm font-medium border border-gray-200 text-gray-700 bg-white rounded-xl hover:bg-gray-50 hover:shadow-sm transition-all duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Export
                </button>

                <button @onclick="OpenModal"
                        class="btn-shine flex items-center gap-2 px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-sky-500 to-blue-500 rounded-xl hover:from-sky-600 hover:to-blue-600 hover:shadow-lg hover:shadow-sky-200/50 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                    Add Position
                </button>
            </div>
        </div>

        <!-- STAT CARDS -->
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-sky-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Total Position</p>
                        <p class="text-xl font-bold text-slate-800 mt-0.5">@totalCount</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Active</p>
                        <p class="text-xl font-bold text-emerald-600 mt-0.5">@(positionList?.Count(x => x.Active == 1) ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Inactive</p>
                        <p class="text-xl font-bold text-slate-500 mt-0.5">@(positionList?.Count(x => x.Active != 1) ?? 0)</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="glass rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100/80 flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                    <div class="w-1.5 h-5 rounded-full bg-gradient-to-b from-sky-400 to-blue-400"></div>
                    <h2 class="text-sm font-semibold text-slate-700">Master Position List</h2>
                    <span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">@totalCount data</span>
                </div>
                <div class="flex items-center gap-1.5 text-xs text-slate-400">
                    &middot; Halaman @currentPage dari @totalPages
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50/70">
                            <th class="px-6 py-3.5 text-center text-[11px] font-semibold text-slate-400 uppercase tracking-wider w-28">Action</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Department</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Division</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Position Name</th>
                            <th class="px-6 py-3.5 text-center text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100/80">
                        @if (positionList != null && positionList.Any())
                        {
                            @foreach (var data in positionList)
                            {
                                <tr class="hover:bg-indigo-50/40 transition">
                                    <td class="px-6 py-4 text-center">
                                        <button @onclick="() => Edit(data)"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-sky-600 bg-sky-50 rounded-lg border border-sky-100 hover:bg-sky-100 transition">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                                            Edit
                                        </button>
                                    </td>
                                    <td class="px-6 py-4 font-medium text-slate-800 text-sm">@(data.DepartmentName ?? "—")</td>
                                    <td class="px-6 py-4 text-slate-500 text-sm">@(data.DivisionName ?? "—")</td>
                                    <td class="px-6 py-4 text-slate-800 text-sm">@(data.PositionName ?? "—")</td>
                                    <td class="px-6 py-4 text-center">
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase border
                                        @(data.Active == 1 ? "bg-emerald-50 text-emerald-600 border-emerald-100" : "bg-slate-100 text-slate-400 border-slate-200")">
                                            <span class="w-1.5 h-1.5 rounded-full @(data.Active == 1 ? "bg-emerald-500" : "bg-slate-300")"></span>
                                            @(data.Active == 1 ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else if (!isLoading)
                        {
                            <tr>
                                <td colspan="5" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center gap-3">
                                        <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center">
                                            <svg class="w-7 h-7 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-slate-500">No positions available</p>
                                            <p class="text-xs text-slate-400 mt-0.5">Klik "Add Position" untuk menambah data baru</p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="px-6 py-4 border-t border-slate-100/80 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500">
                <div class="flex items-center gap-2">
                    <button @onclick="PrevPage" disabled="@(currentPage == 1)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                    </button>
                    <span class="px-1">
                        <span class="text-slate-900 font-semibold">@currentPage</span>
                        <span class="text-slate-400">/ @totalPages</span>
                    </span>
                    <button @onclick="NextPage" disabled="@(currentPage == totalPages)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-xs text-slate-400">Ke halaman</span>
                    <input type="number" min="1" max="@totalPages" @bind="currentPage"
                           class="field w-16 px-3 py-2 text-sm text-center border border-slate-200 rounded-lg bg-white/80 focus:outline-none transition-all" />
                    <button @onclick="GoPage"
                            class="px-4 py-2 text-sm font-semibold text-white bg-slate-800 rounded-lg hover:bg-slate-700 transition-colors">
                        Go
                    </button>
                </div>
            </div>
        </div>
        <div class="text-center py-3">
            <p class="text-xs text-slate-400">Menampilkan @(positionList?.Count ?? 0) dari @totalCount data posisi</p>
        </div>
    </div>

    <!-- ADD MODAL -->
    @if (IsModalOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm modal-overlay">
            <div class="modal-box w-full max-w-2xl bg-white border border-slate-200 rounded-2xl shadow-2xl mx-4">
                <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-lg bg-sky-100 flex items-center justify-center">
                            <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                        </div>
                        <h2 class="text-base font-bold text-slate-800">Add New Position</h2>
                    </div>
                    <button @onclick="CloseModal" class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200 hover:text-slate-800 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Position Name</label>
                        <input @bind="position.PositionName" placeholder="e.g Sales Manager"
                               class="field w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</label>
                        <select @bind="position.Active"
                                class="field appearance-none w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none cursor-pointer transition-all">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                        </select>
                    </div>
                    <div class="md:col-span-2 space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Division</label>
                        <select @bind="selectedDivisionId"
                                class="field appearance-none w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none cursor-pointer transition-all">
                            <option value="">Select Division</option>
                            @foreach (var div in divisionList)
                            {
                                <option value="@div.DivisionId">@div.DivisionName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-slate-100 flex justify-end gap-3">
                    <button @onclick="CloseModal" class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 rounded-xl hover:bg-slate-200 transition-colors">
                        Cancel
                    </button>
                    <button @onclick="Save" class="btn-shine px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-sky-500 to-blue-500 rounded-xl hover:from-sky-600 hover:to-blue-600 transition-all">
                        Save Position
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- EDIT MODAL -->
    @if (IsEditModalOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm modal-overlay">
            <div class="modal-box w-full max-w-2xl bg-white border border-slate-200 rounded-2xl shadow-2xl mx-4">
                <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-lg bg-amber-100 flex items-center justify-center">
                            <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                        </div>
                        <h2 class="text-base font-bold text-slate-800">Edit Position</h2>
                    </div>
                    <button @onclick="CloseEditModal" class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200 hover:text-slate-800 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Position Name</label>
                        <input @bind="positionEdit.PositionName"
                               class="field w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</label>
                        <select @bind="positionEdit.Active"
                                class="field appearance-none w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none cursor-pointer transition-all">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                        </select>
                    </div>
                    <div class="md:col-span-2 space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Division</label>
                        <select @bind="selectedDivisionId"
                                class="field appearance-none w-full px-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-white focus:outline-none cursor-pointer transition-all">
                            <option value="">Select Division</option>
                            @foreach (var div in divisionList)
                            {
                                <option value="@div.DivisionId">@div.DivisionName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-slate-100 flex justify-end gap-3">
                    <button @onclick="CloseEditModal" class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 rounded-xl hover:bg-slate-200 transition-colors">
                        Cancel
                    </button>
                    <button @onclick="Update" class="btn-shine px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-amber-500 to-orange-500 rounded-xl hover:from-amber-600 hover:to-orange-600 transition-all">
                        Update Changes
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- LOADING -->
    @if (isLoading)
    {
        <div class="fixed inset-0 z-50 bg-white/60 backdrop-blur-sm flex items-center justify-center">
            <div class="flex flex-col items-center gap-3 bg-white px-8 py-6 rounded-2xl shadow-xl border border-slate-100">
                <div class="relative w-12 h-12">
                    <div class="absolute inset-0 rounded-full border-4 border-slate-200"></div>
                    <div class="absolute inset-0 rounded-full border-4 border-transparent border-t-sky-500 animate-spin"></div>
                </div>
                <p class="text-sm font-medium text-slate-600">Memuat data...</p>
            </div>
        </div>
    }
</div>

@code {
    private List<VPosition> positionList = new();
    private Position position = new();
    private VPosition positionEdit = new();
    private List<VDivision> divisionList = new();

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;

    private bool IsModalOpen = false;
    private bool IsEditModalOpen = false;
    private string selectedDivisionId;

    private bool isLoading = false;

    private async Task OpenModal()
    {
        position = new Position(); 
        selectedDivisionId = "";
        divisionList = (await _divisionService.GetAll()).ToList();
        IsModalOpen = true;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
    }

    private void CloseEditModal()
    {
        IsEditModalOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        var result = await _positionService.GetPaged(currentPage, pageSize);
        currentPage = result.PageNumber;
        pageSize = result.PageSize;
        totalCount = result.TotalCount;
        totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
        positionList = result.Items.ToList();
    }

    private async Task ExportExcel()
    {
        var result = await _positionService.GetAll();
        var fileByte = _positionService.GenerateExportPosition(result);
        var fileBase64 = Convert.ToBase64String(fileByte);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "Position.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            fileBase64
        );
    }

    private async Task Save()
    {
        position.DivisionId = selectedDivisionId;
        await _positionService.Create(position);
        ClearForm();
        CloseModal();
        isLoading = true;
        await LoadData();
        isLoading = false;
    }

    private async Task Update()
    {
        position.DivisionId = selectedDivisionId;
        position.PositionId = positionEdit.PositionId;
        position.PositionName = positionEdit.PositionName;
        position.Active = positionEdit.Active;

        await _positionService.Update(position);
        ClearForm();
        CloseEditModal();
        isLoading = true;
        await LoadData();
        isLoading = false;
    }

    private void ClearForm()
    {
        position = new Position();
        positionEdit = new VPosition();
        selectedDivisionId = "";
    }

    private async Task Edit(VPosition data)
    {
        positionEdit.PositionId = data.PositionId;
        positionEdit.PositionName = data.PositionName;
        positionEdit.DivisionId = data.DivisionId;
        positionEdit.DivisionName = data.DivisionName;
        positionEdit.Active = data.Active;
        
        selectedDivisionId = data.DivisionId;
        divisionList = (await _divisionService.GetAll()).ToList();
        
        IsEditModalOpen = true;
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }

    private async Task GoPage()
    {
        if (currentPage >= 1 && currentPage <= totalPages)
        {
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }
}