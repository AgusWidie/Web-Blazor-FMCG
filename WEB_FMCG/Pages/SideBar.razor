            _ => "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        };

        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "class", "w-[20px] h-[20px]");
        builder.AddAttribute(2, "fill", "none");
        builder.AddAttribute(3, "stroke", "currentColor");
        builder.AddAttribute(4, "stroke-width", "1.5");
        builder.AddAttribute(5, "stroke-linecap", "round");
        builder.AddAttribute(6, "stroke-linejoin", "round");
        builder.AddAttribute(7, "viewBox", "0 0 24 24");
        
        builder.OpenElement(8, "path");
        builder.AddAttribute(9, "d", path);
        builder.CloseElement();
        
        builder.CloseElement();
    };

    public class SidebarMenuHeader { public string Title { get; set; } = ""; public List<SidebarMenuItem> Items { get; set; } = new(); }
    public class SidebarMenuItem { public string Title { get; set; } = ""; public string Url { get; set; } = ""; public string Icon { get; set; } = ""; }

    private List<VRoleMenuHeader> lstMenuHeaderRoleId = new();
    private List<VRoleMenuUser> lstMenuUser = new();
    private string? token;
    private string? roleId;

    private bool IsActive(string pagePath) => NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower().Contains(pagePath.ToLower());

    protected override async Task OnInitializedAsync()
    {
        var token = await AuthService.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) throw new InvalidOperationException("User not logged in");

        var roleId = AuthService.CurrentSession?.RoleId;
        if (string.IsNullOrWhiteSpace(roleId)) { Console.WriteLine("RoleId kosong"); return; }

        lstMenuHeaderRoleId = (await _menuService.GetMenuHeaderRoleId(roleId)).ToList();
        lstMenuUser = (await _menuService.GetMenuUser(roleId)).ToList();

        userName = await AuthService.GetUserNameAsync();
        if (string.IsNullOrWhiteSpace(userName)) throw new InvalidOperationException("User not logged in");
    }

    void Clear()
    {
        List<VRoleMenuHeader> lstMenuHeaderRoleId = new();
        List<VRoleMenuUser> lstMenuUser = new();
    }

    private Dictionary<string, bool> expandedHeaders = new();
    private void ToggleHeader(string headerId) { if (expandedHeaders.ContainsKey(headerId)) expandedHeaders[headerId] = !expandedHeaders[headerId]; else expandedHeaders[headerId] = true; }
    private bool IsExpanded(string headerId) => expandedHeaders.ContainsKey(headerId) && expandedHeaders[headerId];

    private async Task Logout()
    {
        LoginRequest loginReq = new LoginRequest();
        userName = await AuthService.GetUserNameAsync();
        if (string.IsNullOrWhiteSpace(userName)) throw new InvalidOperationException("User not logged in");
        
        loginReq.UserName = userName;
        loginReq.DeviceId = "DSWfsnrwh7428";
        loginReq.Password = "DSWfsnrwh7428";

        var apiRes = await _logoutService.LogoutUser(loginReq);
        if (apiRes.Success == true) Nav.NavigateTo("/login"); 
    }
}