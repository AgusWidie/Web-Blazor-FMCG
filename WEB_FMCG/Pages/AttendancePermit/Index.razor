    void Clear()
    {
        List<VAttendance> attendanceList = new();

    }

    async void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadData();
        }
    }

    async void PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
