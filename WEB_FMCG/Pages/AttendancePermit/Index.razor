@page "/attendance-permit"
@using System.Text.Json
@using System.Threading.Tasks

@inject IJSRuntime JS
@inject IAttendancePermitService _attendancePermitService

<style>
    .ap-page::-webkit-scrollbar { width: 5px; height: 5px; }
    .ap-page::-webkit-scrollbar-track { background: transparent; }
    .ap-page::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
    .glass {
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 4px 24px rgba(15,23,42,0.05);
    }
    .ap-page tbody tr { transition: all 0.18s ease; }
    .ap-page tbody tr:hover {
        background: linear-gradient(135deg, #f0f9ff 0%, #ecfdf5 100%);
        box-shadow: inset 3px 0 0 #0ea5e9;
    }
    .btn-shine { position: relative; overflow: hidden; }
    .btn-shine::after {
        content: ''; position: absolute; top: -50%; left: -60%;
        width: 40%; height: 200%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: skewX(-20deg); transition: left 0.5s ease;
    }
    .btn-shine:hover::after { left: 120%; }
    .field:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14,165,233,0.1);
    }
    .dot-bg {
        background-image: radial-gradient(circle, #e2e8f0 0.8px, transparent 0.8px);
        background-size: 22px 22px;
    }
    .stat-card { transition: all 0.2s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(15,23,42,0.07); }
    .orb-a {
        position: fixed; width: 380px; height: 380px; border-radius: 50%;
        background: radial-gradient(circle, rgba(14,165,233,0.07), transparent 70%);
        top: -90px; right: -90px; pointer-events: none;
    }
    .orb-b {
        position: fixed; width: 320px; height: 320px; border-radius: 50%;
        background: radial-gradient(circle, rgba(16,185,129,0.05), transparent 70%);
        bottom: -70px; left: -70px; pointer-events: none;
    }
    .photo-thumb {
        transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .photo-thumb:hover {
        transform: scale(3);
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        z-index: 30;
        border-color: #0ea5e9 !important;
        border-width: 2px;
    }
    .page-btn { transition: all 0.15s ease; }
    .page-btn:not(:disabled):hover {
        background: #0ea5e9; color: white; border-color: #0ea5e9; transform: scale(1.05);
    }
    .page-btn:not(:disabled):active { transform: scale(0.97); }
</style>

<div class="ap-page relative min-h-screen bg-gradient-to-br from-slate-50 via-sky-50/30 to-emerald-50/20 text-gray-900 font-sans">

    <div class="orb-a"></div>
    <div class="orb-b"></div>
    <div class="dot-bg absolute inset-0 opacity-35 pointer-events-none"></div>

    <div class="relative z-10 max-w-[90rem] mx-auto p-6 lg:p-10 space-y-7">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sky-500 to-cyan-400 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-semibold text-sky-600 uppercase tracking-widest">Sales Monitoring</span>
                </div>
                <h1 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">Attendance Permit</h1>
                <p class="text-sm text-slate-400">Rekap izin keluar sales per periode</p>
            </div>
            <button @onclick="ExportExcel"
                    class="group flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-slate-600 bg-white/80 backdrop-blur border border-slate-200/80 rounded-xl hover:border-sky-300 hover:text-sky-600 hover:shadow-md hover:shadow-sky-100/50 transition-all">
                <svg class="w-4 h-4 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                </svg>
                Export Excel
            </button>
        </div>


        <!-- STAT CARDS -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-sky-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Total Permit</p>
                        <p class="text-xl font-bold text-slate-800 mt-0.5">@totalCount</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Approved</p>
                        <p class="text-xl font-bold text-emerald-600 mt-0.5">@(attendancePermitList?.Count(x => x.ApproveDate != null) ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Rejected</p>
                        <p class="text-xl font-bold text-red-600 mt-0.5">@(attendancePermitList?.Count(x => x.RejectDate != null) ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Cancelled</p>
                        <p class="text-xl font-bold text-amber-600 mt-0.5">@(attendancePermitList?.Count(x => x.CancelDate != null) ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Period</p>
                        <p class="text-xl font-bold text-violet-600 mt-0.5">@(monthList.TryGetValue(month, out var pm) ? pm.Substring(0,3) : "—") @year</p>
                    </div>
                </div>
            </div>
        </div>


        <!-- FILTER -->
        <div class="glass rounded-2xl p-6">
            <div class="flex flex-wrap items-end gap-5">
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Period Month</label>
                    <select @bind="month"
                            class="field px-4 py-3 text-sm bg-white border border-slate-200 rounded-xl focus:outline-none transition-all appearance-none cursor-pointer min-w-[200px]">
                        @foreach (var m in monthList)
                        {
                            <option value="@m.Key">@m.Value</option>
                        }
                    </select>
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Period Year</label>
                    <select @bind="year"
                            class="field px-4 py-3 text-sm bg-white border border-slate-200 rounded-xl focus:outline-none transition-all appearance-none cursor-pointer min-w-[150px]">
                        @foreach (var y in yearList)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <button @onclick="LoadData"
                        class="btn-shine flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-sky-500 to-cyan-500 rounded-xl hover:from-sky-600 hover:to-cyan-600 hover:shadow-lg hover:shadow-sky-200/50 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/>
                    </svg>
                    Apply Filter
                </button>
            </div>
        </div>


        <!-- TABLE -->
        <div class="glass rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100/80 flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                    <div class="w-1.5 h-5 rounded-full bg-gradient-to-b from-sky-400 to-cyan-400"></div>
                    <h2 class="text-sm font-semibold text-slate-700">Daftar Izin</h2>
                    <span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">@totalCount data</span>
                </div>
                <div class="flex items-center gap-1.5 text-xs text-slate-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                    </svg>
                    Halaman @currentPage dari @totalPages
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50/70">
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Sales Name</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Start Date</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">End Date</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Created</th>
                            <th class="px-4 py-3.5 text-center text-[11px] font-semibold text-slate-400 uppercase tracking-wider w-24">Photo</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Approve</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Reject</th>
                            <th class="px-4 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Cancel</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-100/80">

                        @if (attendancePermitList != null && attendancePermitList.Any())
                        {
                            @foreach (var data in attendancePermitList)
                            {
                                <tr>
                                    <td class="px-4 py-3.5">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sky-100 to-cyan-100 flex items-center justify-center flex-shrink-0">
                                                <svg class="w-3.5 h-3.5 text-sky-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                                                </svg>
                                            </div>
                                            <span class="text-sm text-slate-700 font-medium whitespace-nowrap">@(data.SalesName ?? "—")</span>
                                        </div>
                                    </td>

                                    <td class="px-4 py-3.5 whitespace-nowrap">
                                        <span class="text-sm text-slate-700">@data.StartDate.ToString("dd/MM/yyyy HH:mm")</span>
                                    </td>

                                    <td class="px-4 py-3.5 whitespace-nowrap">
                                        <span class="text-sm text-slate-600">@(data.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span>
                                    </td>

                                    <td class="px-4 py-3.5 whitespace-nowrap">
                                        <span class="text-xs text-slate-400">@data.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                                    </td>

                                    <td class="px-4 py-3.5 text-center">
                                        @if (!string.IsNullOrEmpty(data.FilePhoto))
                                        {
                                            <img class="photo-thumb w-11 h-11 object-cover rounded-xl border-2 border-slate-200 mx-auto cursor-pointer"
                                                 src="data:image/jpeg;base64,@data.FilePhoto" />
                                        }
                                        else
                                        {
                                            <div class="mx-auto w-11 h-11 rounded-xl bg-slate-100 flex items-center justify-center">
                                                <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13"/>
                                                </svg>
                                            </div>
                                        }
                                    </td>

                                    <td class="px-4 py-3.5">
                                        @if (data.ApproveDate != null)
                                        {
                                            <div class="inline-flex flex-col gap-0.5 px-2.5 py-1.5 rounded-xl bg-emerald-50 border border-emerald-200/60">
                                                <div class="flex items-center gap-1">
                                                    <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                                                    <span class="text-xs font-bold text-emerald-700">Approved</span>
                                                </div>
                                                <span class="text-[11px] text-emerald-600 pl-4">@data.ApproveDate.Value.ToString("dd/MM HH:mm")</span>
                                                @if (!string.IsNullOrEmpty(data.ApproveBy))
                                                {
                                                    <span class="text-[11px] text-emerald-500 pl-4">by @(data.ApproveBy)</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">—</span>
                                        }
                                    </td>

                                    <td class="px-4 py-3.5">
                                        @if (data.RejectDate != null)
                                        {
                                            <div class="inline-flex flex-col gap-0.5 px-2.5 py-1.5 rounded-xl bg-red-50 border border-red-200/60">
                                                <div class="flex items-center gap-1">
                                                    <svg class="w-3 h-3 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                                    <span class="text-xs font-bold text-red-700">Rejected</span>
                                                </div>
                                                <span class="text-[11px] text-red-600 pl-4">@data.RejectDate.Value.ToString("dd/MM HH:mm")</span>
                                                @if (!string.IsNullOrEmpty(data.RejectBy))
                                                {
                                                    <span class="text-[11px] text-red-500 pl-4">by @(data.RejectBy)</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">—</span>
                                        }
                                    </td>

                                    <td class="px-4 py-3.5">
                                        @if (data.CancelDate != null)
                                        {
                                            <div class="inline-flex flex-col gap-0.5 px-2.5 py-1.5 rounded-xl bg-amber-50 border border-amber-200/60">
                                                <div class="flex items-center gap-1">
                                                    <svg class="w-3 h-3 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                    <span class="text-xs font-bold text-amber-700">Cancelled</span>
                                                </div>
                                                <span class="text-[11px] text-amber-600 pl-4">@data.CancelDate.Value.ToString("dd/MM HH:mm")</span>
                                                @if (!string.IsNullOrEmpty(data.CancelBy))
                                                {
                                                    <span class="text-[11px] text-amber-500 pl-4">by @(data.CancelBy)</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center gap-3">
                                        <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center">
                                            <svg class="w-7 h-7 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-slate-500">No attendance permit data available</p>
                                            <p class="text-xs text-slate-400 mt-0.5">Coba ubah filter periode di atas</p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="px-6 py-4 border-t border-slate-100/80 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500">
                <div class="flex items-center gap-2">
                    <button @onclick="PrevPage"
                            disabled="@(currentPage == 1)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                    </button>
                    <span class="px-1">
                        <span class="text-slate-900 font-semibold">@currentPage</span>
                        <span class="text-slate-400">/ @totalPages</span>
                    </span>
                    <button @onclick="NextPage"
                            disabled="@(currentPage == totalPages)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-xs text-slate-400">Ke halaman</span>
                    <input type="number" min="1" max="@totalPages" @bind="currentPage"
                           class="field w-16 px-3 py-2 text-sm text-center border border-slate-200 rounded-lg bg-white/80 focus:outline-none transition-all" />
                    <button @onclick="GoPage"
                            class="px-4 py-2 text-sm font-semibold text-white bg-slate-800 rounded-lg hover:bg-slate-700 transition-colors">Go</button>
                </div>
            </div>
        </div>

        <div class="text-center py-3">
            <p class="text-xs text-slate-400">Menampilkan @(attendancePermitList?.Count ?? 0) dari @totalCount data izin</p>
        </div>
    </div>


    <!-- LOADING -->
    @if (isLoading)
    {
        <div class="fixed inset-0 z-50 bg-white/60 backdrop-blur-sm flex items-center justify-center">
            <div class="flex flex-col items-center gap-3">
                <div class="relative w-12 h-12">
                    <div class="absolute inset-0 rounded-full border-4 border-slate-200"></div>
                    <div class="absolute inset-0 rounded-full border-4 border-transparent border-t-sky-500 animate-spin"></div>
                </div>
                <p class="text-sm font-medium text-slate-600">Memuat data...</p>
            </div>
        </div>
    }

</div>


@code {
    private List<VAttendancePermit> attendancePermitList = new();

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int pageNumber = 1;
    private int totalPages = 0;
    private string token = "";

    private int month = 0;
    private int year = 0;

    private bool isLoading = false;

    private List<int> yearList = new();
    private Dictionary<int, string> monthList = new()
    {
        { 1, "January" }, { 2, "February" }, { 3, "March" },
        { 4, "April" }, { 5, "May" }, { 6, "June" },
        { 7, "July" }, { 8, "August" }, { 9, "September" },
        { 10, "October" }, { 11, "November" }, { 12, "December" }
    };

    protected override async Task OnInitializedAsync()
    {
        int currentYear = DateTime.Now.Year;
        month = DateTime.Now.Month; // Default bulan sekarang
        // Membuat range: 2 tahun lalu s/d 2 tahun depan
        for (int i = currentYear - 2; i <= currentYear + 2; i++)
        {
            yearList.Add(i);
        }

        // Set default ke tahun sekarang jika diinginkan
        year = currentYear;

        isLoading = true;
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
       
        var result = await _attendancePermitService.GetPaged(currentPage, month, year);
        pageNumber = result.PageNumber;
        pageSize = result.PageSize;
        totalCount = result.TotalCount;
        totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);

        attendancePermitList = result.Items;
    }
 

    private async Task ExportExcel()
    {
        var result = await _attendancePermitService.AttendancePermitExport(month, year);
        var dataList = result.ToList();
        var fileByte = _attendancePermitService.GenerateExportAttendancePermit(dataList);
        var fileBase64 = Convert.ToBase64String(fileByte);

        await JS.InvokeVoidAsync(
             "downloadFile",
             "AttendancePermit.xlsx",
             "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
             fileBase64
         );
    }

