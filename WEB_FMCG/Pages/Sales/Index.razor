</div>


@code {
    private List<VSale> salesList = new();
    private List<VPosition> positionList = new();
    private Sale sales = new();
    private VSale salesEdit = new();

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;

    private string selectedPositionId = "";

    private bool IsModalOpen = false;
    private bool IsEditModalOpen = false;
    private bool IsLoading = false;

    private bool isSuccess = false;
    private bool isError = false;
    private bool isToastExiting = false;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        await LoadData();
        IsLoading = false;
    }

    private async Task LoadData()
    {
        var result = await _salesService.GetPaged(currentPage, pageSize);
        currentPage = result.PageNumber;
        pageSize = result.PageSize;
        totalCount = result.TotalCount;
        totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
        salesList = result.Items;
    }

    private async Task OpenModal()
    {
        sales = new Sale();
        selectedPositionId = "";

        var posResult = await _positionService.GetAll();
        positionList = posResult.ToList();

        IsModalOpen = true;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
    }

    private void CloseEditModal()
    {
        IsEditModalOpen = false;
    }

    private async Task Save()
    {
        sales.PositionId = selectedPositionId;
        await _salesService.Create(sales);
        IsModalOpen = false;
        ShowToast(true, "Sales berhasil ditambahkan");
        sales = new();
        selectedPositionId = "";
        await LoadData();
    }

    private async Task Edit(VSale data)
    {
        salesEdit.SalesId = data.SalesId;
        salesEdit.SalesName = data.SalesName;
        salesEdit.PositionId = data.PositionId;
        salesEdit.Gender = data.Gender;
        salesEdit.Religion = data.Religion;
        salesEdit.PlaceOfBirth = data.PlaceOfBirth;
        salesEdit.DateOfBirth = data.DateOfBirth;
        salesEdit.Education = data.Education;
        salesEdit.Email = data.Email;
        salesEdit.Telephone = data.Telephone;
        salesEdit.UserName = data.UserName;

        selectedPositionId = data.PositionId ?? "";

        var posResult = await _positionService.GetAll();
        positionList = posResult.ToList();

        IsEditModalOpen = true;
    }

    private async Task Update()
    {
        sales.SalesId = salesEdit.SalesId;
        sales.SalesName = salesEdit.SalesName;
        sales.PositionId = selectedPositionId;
        sales.Gender = salesEdit.Gender;
        sales.Religion = salesEdit.Religion;
        sales.PlaceOfBirth = salesEdit.PlaceOfBirth;
        sales.DateOfBirth = salesEdit.DateOfBirth;
        sales.Education = salesEdit.Education;
        sales.Email = salesEdit.Email;
        sales.Telephone = salesEdit.Telephone;

        await _salesService.Update(sales);
        IsEditModalOpen = false;
        ShowToast(true, "Sales berhasil diperbarui");
        sales = new();
        salesEdit = new();
        selectedPositionId = "";
        await LoadData();
    }

    private async Task ExportExcel()
    {
        var result = await _salesService.GetAll();
        var dataList = result.ToList();
        var fileByte = _salesService.GenerateExportSales(dataList);
        var fileBase64 = Convert.ToBase64String(fileByte);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "Sales.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            fileBase64
        );
    }

    private void ShowToast(bool success, string msg)
    {
        isSuccess = success;
        isError = !success;
        isToastExiting = false;
        message = msg;

        Task.Run(async () =>
        {
            await Task.Delay(3000);
            DismissToast();
        });
    }

    private async Task DismissToast()
    {
        isToastExiting = true;
        await Task.Delay(250);
        isSuccess = false;
        isError = false;
        isToastExiting = false;
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            IsLoading = true;
            await LoadData();
            IsLoading = false;
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            IsLoading = true;
            await LoadData();
            IsLoading = false;
        }
    }

    private async Task GoPage()
    {
        if (currentPage >= 1 && currentPage <= totalPages)
        {
            IsLoading = true;
            await LoadData();
            IsLoading = false;
        }
    }
}