@page "/"
@page "/login"

@using WEB_FMCG.Auth
@using WEB_FMCG.Models
@using WEB_FMCG.Services
@using WEB_FMCG.DTO

@layout LoginLayout
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ILoginService _loginService

<style>
    :root {
        --bg: #f5f5f0;
        --card: #ffffff;
        --border: rgba(0,0,0,0.06);
        --border-focus: rgba(13,148,136,0.12);
        --accent: #0d9488;
        --accent-light: rgba(13,148,136,0.06);
        --accent-glow: rgba(13,148,136,0.15);
        --text: #111827;
        --text-sec: #4b5563;
        --text-muted: #9ca3af;
        --text-label: #6b7280;
        --input-bg: #f9fafb;
        --input-border: #e5e7eb;
        --err-bg: #fef2f2;
        --err-border: #fecaca;
        --err-text: #b91c1c;
    }

    .login-scene {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        background: var(--bg);
    }

    .login-scene .dots {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(0,0,0,0.035) 1px, transparent 1px);
        background-size: 28px 28px;
    }

    .login-scene .wash {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 60% 50% at 15% 85%, rgba(13,148,136,0.04) 0%, transparent 60%),
            radial-gradient(ellipse 50% 60% at 85% 15%, rgba(13,148,136,0.03) 0%, transparent 60%);
    }

    .login-scene .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        animation: blobMove 20s ease-in-out infinite;
    }

    .blob-1 {
        width: 420px; height: 420px;
        background: rgba(13,148,136,0.05);
        top: -8%; right: -5%;
    }

    .blob-2 {
        width: 350px; height: 350px;
        background: rgba(13,148,136,0.04);
        bottom: -8%; left: -5%;
        animation-delay: -7s;
    }

    .blob-3 {
        width: 280px; height: 280px;
        background: rgba(13,148,136,0.03);
        top: 45%; left: 45%;
        animation-delay: -14s;
        animation-duration: 26s;
    }

    @@keyframes blobMove {
        0%,100% { transform: translate(0,0) scale(1); }
        25% { transform: translate(25px,-35px) scale(1.04); }
        50% { transform: translate(-18px,18px) scale(0.96); }
        75% { transform: translate(12px,25px) scale(1.02); }
    }

    #loginParticles {
        position: absolute;
        inset: 0;
        z-index: 1;
    }

    /* Floating stats */
    .flt-stat {
        position: fixed;
        z-index: 5;
        padding: 12px 18px;
        border-radius: 14px;
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.04);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
        pointer-events: none;
    }

    .flt-stat .val {
        font-family: 'Outfit', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
    }

    .flt-stat .lbl {
        font-size: 10px;
        color: var(--text-muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 1px;
    }

    .flt-stat .chg {
        font-size: 10px;
        font-weight: 600;
        color: #059669;
        margin-top: 2px;
    }

    .fs1 { top:14%; left:5%; animation: fA 22s ease-in-out infinite; }
    .fs2 { top:55%; right:4%; animation: fB 26s ease-in-out infinite; }
    .fs3 { bottom:14%; left:7%; animation: fC 20s ease-in-out infinite; }

    @@keyframes fA { 0%,100%{transform:translateY(0);opacity:.6} 50%{transform:translateY(-14px);opacity:.85} }
    @@keyframes fB { 0%,100%{transform:translateY(0);opacity:.5} 50%{transform:translateY(10px);opacity:.8} }
    @@keyframes fC { 0%,100%{transform:translateY(0);opacity:.55} 50%{transform:translateY(-10px);opacity:.75} }

    /* Wrapper */
    .login-wrap {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 420px;
        padding: 20px;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Card */
    .login-card {
        position: relative;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 40px 36px 32px;
        box-shadow: 0 24px 80px rgba(0,0,0,0.1), 0 1px 2px rgba(0,0,0,0.04);
        width: 100%;
        animation: cardIn .7s cubic-bezier(.16,1,.3,1) both;
        transition: border-color .3s ease;
    }

    @@keyframes cardIn {
        from { opacity:0; transform:translateY(24px) scale(.98); }
        to { opacity:1; transform:translateY(0) scale(1); }
    }

    @@keyframes shakeCard {
        0%,100%{transform:translateX(0)} 15%{transform:translateX(-6px)} 30%{transform:translateX(5px)}
        45%{transform:translateX(-3px)} 60%{transform:translateX(2px)}
    }

    .login-card::before {
        content: '';
        position: absolute;
        top: 0; left: 40px; right: 40px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
        border-radius: 0 0 2px 2px;
    }

    /* Header */
    .lg-header {
        text-align: center;
        margin-bottom: 32px;
        animation: fadeUp .6s .1s cubic-bezier(.16,1,.3,1) both;
    }

    .lg-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 52px; height: 52px;
        border-radius: 16px;
        background: var(--accent-light);
        border: 1px solid rgba(13,148,136,0.1);
        margin-bottom: 16px;
        position: relative;
        transition: transform .4s cubic-bezier(.16,1,.3,1), box-shadow .4s ease;
    }

    .lg-icon:hover {
        transform: scale(1.06) rotate(-2deg);
        box-shadow: 0 4px 20px var(--accent-glow);
    }

    .lg-icon i { font-size: 20px; color: var(--accent); }

    .lg-pulse {
        position: absolute; inset: -3px;
        border-radius: 18px;
        border: 1px solid rgba(13,148,136,0.12);
        animation: lPulse 3s ease-in-out infinite;
    }

    @@keyframes lPulse { 0%,100%{opacity:.3;transform:scale(1)} 50%{opacity:.6;transform:scale(1.05)} }

    .lg-header h1 {
        font-family: 'Outfit', sans-serif;
        font-size: 19px; font-weight: 800;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--text);
    }

    .lg-header .tag {
        font-size: 10px; font-weight: 600;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--accent);
        margin-top: 3px;
        opacity: .75;
    }

    @@keyframes fadeUp {
        from { opacity:0; transform:translateY(14px); }
        to { opacity:1; transform:translateY(0); }
    }

    /* Error */
    .err-box {
        display: none;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        padding: 11px 14px;
        border-radius: 12px;
        background: var(--err-bg);
        border: 1px solid var(--err-border);
        font-size: 12px; font-weight: 500;
        color: var(--err-text);
        animation: shakeIn .5s cubic-bezier(.36,.07,.19,.97) both;
    }

    .err-box.show { display: flex; }

    .err-box i { font-size: 14px; color: #dc2626; flex-shrink: 0; }

    @@keyframes shakeIn {
        0%{opacity:0;transform:translateX(-8px)} 20%{transform:translateX(6px)}
        40%{transform:translateX(-4px)} 60%{transform:translateX(2px)} 100%{opacity:1;transform:translateX(0)}
    }

    /* Form */
    .lg-form { animation: fadeUp .6s .25s cubic-bezier(.16,1,.3,1) both; }

    .fld { margin-bottom: 18px; }

    .fld-label {
        display: block;
        font-size: 11px; font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--text-label);
        margin-bottom: 7px;
    }

    .fld-wrap { position: relative; }

    .fld-wrap .ic {
        position: absolute; left: 14px; top: 50%;
        transform: translateY(-50%);
        font-size: 13px;
        color: var(--text-muted);
        transition: color .3s ease;
        pointer-events: none;
    }

    .fld-input {
        width: 100%; height: 46px;
        border-radius: 12px;
        border: 1.5px solid var(--input-border);
        background: var(--input-bg);
        padding: 0 46px 0 42px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 14px;
        color: var(--text);
        outline: none;
        transition: all .25s ease;
    }

    .fld-input::placeholder { color: #c4c9d1; }

    .fld-input:focus {
        border-color: var(--accent);
        background: #fff;
        box-shadow: 0 0 0 3px var(--accent-light);
    }

    .fld-input:focus ~ .ic { color: var(--accent); }

    .focus-line {
        position: absolute; bottom: 0; left: 50%;
        width: 0; height: 2px;
        background: var(--accent);
        border-radius: 2px;
        transition: all .35s cubic-bezier(.16,1,.3,1);
        transform: translateX(-50%);
    }

    .fld-input:focus ~ .focus-line { width: 60%; }

    .tgl-pw {
        position: absolute; right: 10px; top: 50%;
        transform: translateY(-50%);
        background: none; border: none;
        color: var(--accent);
        font-size: 10px; font-weight: 700;
        letter-spacing: .08em;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        transition: background .2s ease;
    }

    .tgl-pw:hover { background: var(--accent-light); }

    /* Button */
    .btn-lg {
        position: relative;
        width: 100%; height: 48px;
        border: none; border-radius: 12px;
        background: var(--accent);
        font-family: 'Space Grotesk', sans-serif;
        font-size: 14px; font-weight: 600;
        letter-spacing: .04em;
        color: #fff;
        cursor: pointer;
        overflow: hidden;
        transition: all .35s cubic-bezier(.16,1,.3,1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 26px;
    }

    .btn-lg::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,.12), transparent);
        opacity: 0;
        transition: opacity .3s ease;
    }

    .btn-lg:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 24px rgba(13,148,136,.25);
    }

    .btn-lg:hover::before { opacity: 1; }

    .btn-lg:active {
        transform: translateY(0) scale(.98);
        box-shadow: 0 2px 8px rgba(13,148,136,.2);
    }

    .btn-lg:disabled {
        opacity: .55; cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
    }

    .btn-shimmer {
        position: absolute; top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.1), transparent);
        animation: shimmer 4s ease-in-out infinite;
    }

    @@keyframes shimmer { 0%,100%{left:-100%} 50%{left:100%} }

    .spinner {
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,.25);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .6s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Footer */
    .lg-footer {
        text-align: center;
        margin-top: 28px;
        font-size: 10px;
        color: var(--text-muted);
        font-weight: 500;
        letter-spacing: .03em;
        animation: fadeUp .6s .35s cubic-bezier(.16,1,.3,1) both;
    }

    .lg-footer .sep {
        display: inline-block;
        width: 3px; height: 3px;
        border-radius: 50%;
        background: #d1d5db;
        margin: 0 8px;
        vertical-align: middle;
    }

    .live-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 14px;
        font-size: 10px;
        color: var(--text-muted);
        animation: fadeUp .6s .4s cubic-bezier(.16,1,.3,1) both;
    }

    .live-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: #10b981;
        animation: liveP 2.5s ease-in-out infinite;
    }

    @@keyframes liveP {
        0%,100%{opacity:.4;box-shadow:0 0 0 0 rgba(16,185,129,.3)}
        50%{opacity:1;box-shadow:0 0 0 3px rgba(16,185,129,0)}
    }

    /* Toast */
    @@keyframes toastIn {
        from { opacity:0; transform:translateY(-14px) scale(.96); }
        to { opacity:1; transform:translateY(0) scale(1); }
    }

    .toast-n {
        position: fixed; top: 20px; right: 20px; z-index: 999;
        display: flex; align-items: center; gap: 10px;
        padding: 13px 18px; border-radius: 12px;
        background: #fff;
        border: 1px solid rgba(13,148,136,.15);
        color: #0d9488;
        font-size: 12px; font-weight: 600;
        font-family: 'Space Grotesk', sans-serif;
        box-shadow: 0 8px 30px rgba(0,0,0,.08);
        animation: toastIn .45s cubic-bezier(.16,1,.3,1) both;
    }

    @@media (max-width: 768px) {
        .flt-stat { display: none; }
        .login-card { padding: 32px 24px 28px; }
    }

    @@media (max-width: 480px) {
        .login-wrap { padding: 16px; }
        .login-card { padding: 28px 20px 24px; border-radius: 16px; }
    }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: .01ms !important;
            transition-duration: .01ms !important;
        }
    }
</style>

<!-- Background -->
<div class="login-scene">
    <div class="dots"></div>
    <div class="wash"></div>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <canvas id="loginParticles"></canvas>
</div>

<!-- Floating Stats -->
<div class="flt-stat fs1">
    <div class="val">2,847</div>
    <div class="lbl">Transaksi Hari Ini</div>
    <div class="chg"><i class="fa-solid fa-arrow-up" style="font-size:8px"></i> 12.8%</div>
</div>
<div class="flt-stat fs2">
    <div class="val">98.7%</div>
    <div class="lbl">Uptime Sistem</div>
    <div class="chg"><i class="fa-solid fa-arrow-up" style="font-size:8px"></i> Stabil</div>
</div>
<div class="flt-stat fs3">
    <div class="val">847</div>
    <div class="lbl">Outlet Aktif</div>
    <div class="chg"><i class="fa-solid fa-arrow-up" style="font-size:8px"></i> 5.2%</div>
</div>

<!-- Login -->
<div class="login-wrap">
    <div class="login-card" id="loginCard">

        <header class="lg-header">
            <div class="lg-icon">
                <div class="lg-pulse"></div>
                <i class="fa-solid fa-chart-column"></i>
            </div>
            <h1>FMCG Analytics</h1>
            <div class="tag">Enterprise Platform</div>
        </header>

        @if (ShowError)
        {
            <div class="err-box show" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@ErrorMessage</span>
            </div>
        }

        <form class="lg-form" @onsubmit="HandleLogin" novalidate>
            <div class="fld">
                <label class="fld-label" for="username">Username</label>
                <div class="fld-wrap">
                    <input type="text"
                           id="username"
                           @bind="loginRequest.UserName"
                           class="fld-input"
                           placeholder="Masukkan username"
                           required
                           autocomplete="username"
                           aria-label="Username" />
                    <i class="fa-solid fa-user ic"></i>
                    <div class="focus-line"></div>
                </div>
            </div>

            <div class="fld">
                <label class="fld-label" for="password">Password</label>
                <div class="fld-wrap">
                    <input type="@PasswordInputType"
                           id="password"
                           @bind="loginRequest.Password"
                           class="fld-input"
                           placeholder="Masukkan password"
                           required
                           autocomplete="current-password"
                           aria-label="Password" />
                    <i class="fa-solid fa-lock ic"></i>
                    <button type="button"
                            class="tgl-pw"
                            @onclick="TogglePassword"
                            aria-label="Tampilkan password">
                        @(PasswordInputType == "password" ? "LIHAT" : "SEMBUNYI")
                    </button>
                    <div class="focus-line"></div>
                </div>
            </div>

            <button type="submit" class="btn-lg" disabled="@IsLoading">
                <span class="btn-shimmer"></span>
                @if (IsLoading)
                {
                    <span class="spinner"></span>
                    <span>Memproses</span>
                }
                else
                {
                    <span>Masuk</span>
                }
            </button>
        </form>

        <div class="lg-footer">
            &copy; @DateTime.Now.Year FMCG Analytics Platform
            <span class="sep"></span>
            Hak cipta dilindungi
        </div>

        <div class="live-bar">
            <div class="live-dot"></div>
            Sistem beroperasi normal
        </div>
    </div>
</div>

@code {

    private LoginRequest loginRequest = new();
    private ApiLoginResponse loginResponse = new();

    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool ShowError { get; set; }
    private string PasswordInputType { get; set; } = "password";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initLoginParticles");
        }
    }

    private async Task HandleLogin()
    {
        ShowError = false;

        if (string.IsNullOrWhiteSpace(loginRequest.UserName) ||
            string.IsNullOrWhiteSpace(loginRequest.Password))
        {
            ErrorMessage = "Username dan password tidak boleh kosong";
            ShowError = true;
            await ShakeCard();
            return;
        }

        IsLoading = true;
        StateHasChanged();

        loginRequest.DeviceId = Guid.NewGuid().ToString().ToUpper().Substring(0, 6);
        var result = await _loginService.LoginUser(loginRequest);
        loginResponse = result;

        if (loginResponse.Success == true)
        {
            Nav.NavigateTo("/sales");
        }
        else
        {
            ErrorMessage = loginResponse.Message ?? "Username atau password yang Anda masukkan salah";
            ShowError = true;
            IsLoading = false;
            StateHasChanged();
            await ShakeCard();
        }

        IsLoading = false;
    }

    private void TogglePassword()
    {
        PasswordInputType = PasswordInputType == "password" ? "text" : "password";
    }

    private async Task ShakeCard()
    {
        await JS.InvokeVoidAsync("shakeLoginCard", "loginCard");
    }
}