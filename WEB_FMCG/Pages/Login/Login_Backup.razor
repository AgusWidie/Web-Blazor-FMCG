@page "/login-backup"

@using DeviceId

<div class="min-h-screen bg-[#F8FAFC] flex items-center justify-center p-6 relative overflow-hidden font-sans">

    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-100/50 rounded-full blur-[120px] -mr-48 -mt-48"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-50/80 rounded-full blur-[100px] -ml-32 -mb-32"></div>

    <div class="relative w-full max-w-[440px]">

        <div class="flex flex-col items-center mb-10">
            <div class="w-14 h-14 bg-white border border-slate-200 shadow-xl shadow-blue-500/10 rounded-2xl flex items-center justify-center mb-4 transition-transform duration-500 hover:scale-110">
                <img src="Logo.png" alt="Logo" class="w-8 h-8 object-contain" />
            </div>
            <h1 class="text-slate-900 text-lg font-black tracking-[0.3em] uppercase">FMCG Analytics</h1>
            <p class="text-blue-500 text-[10px] font-bold uppercase tracking-widest mt-1">Enterprise Solution</p>
        </div>

        <div class="bg-white border border-slate-200/60 rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.04)] p-8 md:p-10 relative overflow-hidden">

            <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-blue-500 to-indigo-500"></div>

            <div class="mb-10">
                <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Sign In</h2>
                <p class="text-slate-500 text-sm mt-1">Access your professional workspace</p>
            </div>

            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center space-x-3 animate-shake">
                    <div class="flex-shrink-0 w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
                        <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <span class="text-red-700 text-xs font-bold uppercase tracking-wide">@Error</span>
                </div>
            }

            <EditForm Model="FormData" OnValidSubmit="HandleSubmit">
                <div class="space-y-6">

                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em] ml-1">Username</label>
                        <div class="group relative transition-all duration-300">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            </div>
                            <InputText @bind-Value="FormData.UserName"
                                       class="w-full bg-slate-50/50 border border-slate-200 text-slate-700 pl-12 pr-4 py-4 rounded-2xl focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all placeholder:text-slate-300 text-sm"
                                       placeholder="Enter username" required />
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <div class="flex justify-between items-center px-1">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em]">Password</label>
                            <a href="#" class="text-[10px] font-bold text-blue-600 hover:text-blue-700 transition-colors uppercase tracking-tighter">Reset Password</a>
                        </div>
                        <div class="group relative transition-all duration-300">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                            </div>
                            <input type="@(ShowPassword ? "text" : "password")" @bind="FormData.Password"
                                   class="w-full bg-slate-50/50 border border-slate-200 text-slate-700 pl-12 pr-12 py-4 rounded-2xl focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all placeholder:text-slate-300 text-sm"
                                   placeholder="••••••••" required />

                            <button type="button" @onclick="ToggleShowPassword" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-300 hover:text-slate-600 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    @if (ShowPassword)
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                                    }
                                    else
                                    {
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    }
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" disabled="@IsLoading"
                            class="w-full relative group overflow-hidden bg-blue-600 text-white py-4 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-lg shadow-blue-200 active:scale-[0.98] transition-all disabled:opacity-70">
                        <span class="relative flex items-center justify-center gap-2">
                            @if (IsLoading)
                            {
                                <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                                <span>Processing...</span>
                            }
                            else
                            {
                                <span>Login to Dashboard</span>
                                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                            }
                        </span>
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="mt-12 text-center">
            <p class="text-slate-400 text-[10px] font-bold uppercase tracking-[0.2em]">
                &copy; @DateTime.Now.Year FMCG Analytics Platform
            </p>
            <div class="flex justify-center gap-4 mt-2">
                <a href="#" class="text-slate-300 hover:text-blue-500 text-[10px] font-bold transition-colors">Privacy Policy</a>
                <span class="text-slate-200 text-[10px]">•</span>
                <a href="#" class="text-slate-300 hover:text-blue-500 text-[10px] font-bold transition-colors">Support Center</a>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-4px);
        }

        75% {
            transform: translateX(4px);
        }
    }

    .animate-shake {
        animation: shake 0.2s ease-in-out 0s 2;
    }
</style>

@code {

    private LoginFormModel FormData { get; set; } = new LoginFormModel();

    private bool ShowPassword { get; set; } = false;
    private bool IsLoading { get; set; } = false;
    private string Error { get; set; } = string.Empty;

    private string deviceId = new DeviceIdBuilder()
                    .AddMachineName()
                    .AddOsVersion()
                    .AddUserName() // Menggunakan nama user sebagai pengganti serial drive
                    .ToString();


    private async Task HandleSubmit()
    {
       
        IsLoading = true;
        Error = string.Empty;
        StateHasChanged();

        try
        {
            string shortId = deviceId.Substring(0, 10);


        }
        catch (OperationCanceledException)
        {
            
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleShowPassword()
    {
        ShowPassword = !ShowPassword;
    }

    // Models
    private class LoginFormModel
    {

        public string UserName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string DeviceId { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = false;
    }

}



