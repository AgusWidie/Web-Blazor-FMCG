<style>
    /* Custom Animations */
    @@keyframes bounce-horizontal {
        0%, 100% {
            transform: translateX(0);
        }

        50% {
            transform: translateX(-3px);
        }
    }

    .animate-bounce-horizontal {
        animation: bounce-horizontal 2s infinite;
    }

    @@keyframes shimmer {
        100% {
            transform: translateX(100%);
        }
    }

    .animate-shimmer {
        animation: shimmer 2s infinite;
    }

    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

@code {

    private List<VRoleMenuHeader> lstMenuHeaderRoleId = new();
    private List<VRoleMenuUser> lstMenuUser = new();
    private string token;
    private string roleId;

    private string GetActiveClass(string pagePath)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        bool isActive = relativePath.Contains(pagePath.ToLower());

        string baseClass = "group relative flex items-center px-4 py-3.5 rounded-2xl text-sm font-bold transition-all duration-500 overflow-hidden ";

        return isActive
            ? baseClass + "bg-indigo-600/10 text-indigo-400 shadow-[inset_0_0_20px_rgba(79,70,229,0.1)] translate-x-1"
            : baseClass + "text-slate-500 hover:bg-slate-800/40 hover:text-slate-200 hover:translate-x-1";
    }

    private bool IsActive(string pagePath)
    {
        return NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower().Contains(pagePath.ToLower());
    }

    protected override void OnInitialized()
    {
        // var result = _menuService.GetMenuHeaderRoleId(token, roleId).Result;
        // lstMenuHeaderRoleId = result.ToList();

        // var resultMenuUser = _menuService.GetMenuUser(token, roleId).Result;
        // lstMenuUser = resultMenuUser.ToList();
    }

    void Clear()
    {
        List<VRoleMenuHeader> lstMenuHeaderRoleId = new();
        List<VRoleMenuUser> lstMenuUser = new();
    }
}