@page "/region-store"
@using WEB_FMCG.Help
@using WEB_FMCG.Services
@using WEB_FMCG.Models
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject IRegionStoreService _regionStoreService
@inject IStoreService _storeService
@inject ICityService _cityService
@inject ISalesService _salesService

<style>
    .pp-page::-webkit-scrollbar { width: 5px; height: 5px; }
    .pp-page::-webkit-scrollbar-track { background: transparent; }
    .pp-page::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
    .glass {
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 4px 24px rgba(15,23,42,0.05);
    }
    .glass-dark {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.85);
        box-shadow: 0 8px 40px rgba(15,23,42,0.1);
    }
    .pp-page tbody tr { transition: all 0.18s ease; }
    .pp-page tbody tr:hover {
        background: linear-gradient(135deg, #eef2ff 0%, #e8e0ff 100%);
        box-shadow: inset 3px 0 0 #818cf8;
    }
    .btn-shine { position: relative; overflow: hidden; }
    .btn-shine::after {
        content: ''; position: absolute; top: -50%; left: -60%;
        width: 40%; height: 200%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
        transform: skewX(-20deg); transition: left 0.5s ease;
    }
    .btn-shine:hover::after { left: 120%; }
    .field:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 3px rgba(129,140,248,0.1);
    }
    .dot-bg {
        background-image: radial-gradient(circle, #e2e8f0 0.8px, transparent 0.8px);
        background-size: 22px 22px;
    }
    .stat-card { transition: all 0.2s ease; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(15,23,42,0.07); }
    .orb-a {
        position: fixed; width: 380px; height: 380px; border-radius: 50%;
        background: radial-gradient(circle, rgba(129,140,248,0.07), transparent 70%);
        top: -90px; right: -90px; pointer-events: none;
    }
    .orb-b {
        position: fixed; width: 320px; height: 320px; border-radius: 50%;
        background: radial-gradient(circle, rgba(168,85,247,0.05), transparent 70%);
        bottom: -70px; left: -70px; pointer-events: none;
    }
    .page-btn { transition: all 0.15s ease; }
    .page-btn:not(:disabled):hover {
        background: #818cf8; color: white; border-color: #818cf8; transform: scale(1.05);
    }
    .page-btn:not(:disabled):active { transform: scale(0.97); }
    .modal-overlay { animation: fadeIn 0.2s ease; }
    .modal-content { animation: slideUp 0.25s ease; }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(16px) scale(0.97); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>

<div class="pp-page relative min-h-screen bg-gradient-to-br from-slate-50 via-indigo-50/30 to-violet-50/20 text-gray-900 font-sans">

    <div class="orb-a"></div>
    <div class="orb-b"></div>
    <div class="dot-bg absolute inset-0 opacity-35 pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto p-6 lg:p-10 space-y-7">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center shadow-sm shadow-indigo-200/50">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z"/>
                        </svg>
                    </div>
                    <span class="text-[11px] font-semibold text-indigo-600 uppercase tracking-widest">Region & Store Management</span>
                </div>
                <h1 class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight">Master Region Store</h1>
                <p class="text-sm text-slate-400">Hubungkan region, city, store, dan sales PIC dalam satu mapping</p>
            </div>

            <div class="flex items-center gap-2">
                <button @onclick="ExportExcel"
                        class="flex items-center gap-2 px-5 py-2.5 text-sm font-medium border border-gray-200 text-gray-700 bg-white rounded-xl hover:bg-gray-50 hover:shadow-sm transition-all duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Export Excel
                </button>

                <button @onclick="OpenModal"
                        class="btn-shine flex items-center gap-2 px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-indigo-500 to-violet-500 rounded-xl hover:from-indigo-600 hover:to-violet-600 hover:shadow-lg hover:shadow-indigo-200/50 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    Tambah Mapping
                </button>
            </div>
        </div>

        <!-- STAT CARDS -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Total Mapping</p>
                        <p class="text-xl font-bold text-slate-800 mt-0.5">@totalCount</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Unique City</p>
                        <p class="text-xl font-bold text-violet-600 mt-0.5">@(regionStoreList.Select(x => x.CityName).Distinct().Count())</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Unique Store</p>
                        <p class="text-xl font-bold text-emerald-600 mt-0.5">@(regionStoreList.Select(x => x.StoreName).Distinct().Count())</p>
                    </div>
                </div>
            </div>
            <div class="stat-card glass rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Unique Sales</p>
                        <p class="text-xl font-bold text-amber-600 mt-0.5">@(regionStoreList.Select(x => x.SalesName).Distinct().Count())</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="glass rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100/80 flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                    <div class="w-1.5 h-5 rounded-full bg-gradient-to-b from-indigo-400 to-violet-400"></div>
                    <h2 class="text-sm font-semibold text-slate-700">Daftar Mapping Region Store</h2>
                    <span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">@totalCount data</span>
                </div>
                <div class="flex items-center gap-1.5 text-xs text-slate-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z"/></svg>
                    Halaman @currentPage dari @totalPages
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50/70">
                            <th class="px-6 py-3.5 text-center text-[11px] font-semibold text-slate-400 uppercase tracking-wider w-28">Action</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Region</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">City / Area</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Store</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Sales PIC</th>
                            <th class="px-6 py-3.5 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Coordinates</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100/80">
                        @if (regionStoreList.Any())
                        {
                            @foreach (var data in regionStoreList)
                            {
                                <tr class="hover:bg-indigo-50/40 transition cursor-pointer">
                                    <td class="px-6 py-4 text-center">
                                        <button @onclick="() => Edit(data)"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-indigo-600 bg-indigo-50 border border-indigo-100 rounded-lg hover:bg-indigo-100 hover:border-indigo-200 transition-all">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                                            Edit
                                        </button>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="font-bold text-slate-800 text-sm">@(data.RegionName ?? "—")</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span class="font-semibold text-slate-700 text-sm">@(data.CityName ?? "—")</span>
                                            <span class="text-[10px] text-slate-400 font-semibold uppercase mt-0.5">@(data.AreaName ?? "—")</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="text-sm text-slate-600">@(data.StoreName ?? "—")</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-semibold text-amber-700 bg-amber-50 border border-amber-100 rounded-lg">
                                            <svg class="w-3 h-3 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                                            @(data.SalesName ?? "—")
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-0.5">
                                            <span class="font-mono text-[11px] text-slate-500 bg-slate-50 px-2 py-0.5 rounded inline-block w-fit">
                                                LAT: @(data.Latitude ?? "—")
                                            </span>
                                            <span class="font-mono text-[11px] text-slate-500 bg-slate-50 px-2 py-0.5 rounded inline-block w-fit">
                                                LNG: @(data.Longitude ?? "—")
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else if (!isLoading)
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center gap-3">
                                        <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center">
                                            <svg class="w-7 h-7 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z"/></svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-slate-500">Belum ada data mapping</p>
                                            <p class="text-xs text-slate-400 mt-0.5">Klik "Tambah Mapping" untuk menambahkan data baru</p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="px-6 py-4 border-t border-slate-100/80 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500">
                <div class="flex items-center gap-2">
                    <button @onclick="PrevPage" disabled="@(currentPage == 1)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
                    </button>
                    <span class="px-1">
                        <span class="text-slate-900 font-semibold">@currentPage</span>
                        <span class="text-slate-400">/ @totalPages</span>
                    </span>
                    <button @onclick="NextPage" disabled="@(currentPage == totalPages)"
                            class="page-btn w-9 h-9 flex items-center justify-center border border-slate-200 rounded-lg text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-xs text-slate-400">Ke halaman</span>
                    <input type="number" min="1" max="@totalPages" @bind="currentPage"
                           class="field w-16 px-3 py-2 text-sm text-center border border-slate-200 rounded-lg bg-white/80 focus:outline-none transition-all" />
                    <button @onclick="GoPage"
                            class="px-4 py-2 text-sm font-semibold text-white bg-slate-800 rounded-lg hover:bg-slate-700 transition-colors">
                        Go
                    </button>
                </div>
            </div>
        </div>

        <div class="text-center py-3">
            <p class="text-xs text-slate-400">Menampilkan @(regionStoreList?.Count ?? 0) dari @totalCount data mapping</p>
        </div>
    </div>

    <!-- MODAL: ADD -->
    @if (IsModalOpen)
    {
        <div class="modal-overlay fixed inset-0 z-50 bg-black/20 backdrop-blur-sm flex items-center justify-center p-4">
            <div class="modal-content glass-dark w-full max-w-lg rounded-2xl overflow-hidden">

                <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                    <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                        </div>
                        <h2 class="text-sm font-bold text-slate-800">Tambah Region Store</h2>
                    </div>
                    <button @onclick="CloseModal"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>

                <div class="px-6 py-5 space-y-4">
                    <div class="space-y-1.5">
                        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Sales PIC</label>
                        <div class="relative">
                            <select @bind="selectedSalesId"
                                    class="field appearance-none w-full px-4 py-2.5 text-sm bg-white/80 border border-slate-200 rounded-xl focus:outline-none cursor-pointer transition-all">
                                <option value="">Pilih Sales...</option>
                                @foreach (var sales in salesList)
                                {
                                    <option value="@sales.SalesId">@sales.SalesName</option>
                                }
                            </select>
