@code {

    private List<VRegionStore> regionStoreList = new();
    private List<VCity> cityList = new();
    private List<VStore> storeList = new();
    private List<VSale> salesList = new();
    private RegionStore regionStore = new();
    private VRegionStore regionStoreEdit = new();

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;

    private string selectedCityId = "";
    private string selectedStoreId = "";
    private string selectedSalesId = "";

    private bool IsModalOpen = false;
    private bool IsEditModalOpen = false;
    private bool isLoading = false;

    private async Task OpenModal()
    {
        regionStore = new();
        selectedSalesId = "";
        selectedCityId = "";
        selectedStoreId = "";

        var resultStore = await _storeService.GetAll();
        storeList = resultStore.ToList();

        var resultCity = await _cityService.GetAll();
        cityList = resultCity.ToList();

        var resultSales = await _salesService.GetAll();
        salesList = resultSales.ToList();

        IsModalOpen = true;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
    }

    private void CloseEditModal()
    {
        IsEditModalOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        var result = await _regionStoreService.GetPaged(currentPage, pageSize);
        currentPage = result.PageNumber;
        pageSize = result.PageSize;
        totalCount = result.TotalCount;
        totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);

        regionStoreList = result.Items;
    }

    private async Task Save()
    {
        regionStore.SalesId = selectedSalesId;
        regionStore.StoreId = selectedStoreId;
        regionStore.CityId = selectedCityId;

        await _regionStoreService.Create(regionStore);
        IsModalOpen = false;
        regionStore = new();
        selectedSalesId = "";
        selectedCityId = "";
        selectedStoreId = "";
        await LoadData();
    }

    private async Task Edit(VRegionStore data)
    {
        regionStoreEdit.Id = data.Id;
        regionStoreEdit.RegionId = data.RegionId;
        regionStoreEdit.RegionName = data.RegionName;
        regionStoreEdit.AreaId = data.AreaId;
        regionStoreEdit.AreaName = data.AreaName;
        regionStoreEdit.CityId = data.CityId;
        regionStoreEdit.CityName = data.CityName;
        regionStoreEdit.StoreId = data.StoreId;
        regionStoreEdit.StoreName = data.StoreName;
        regionStoreEdit.Radius = data.Radius;
        regionStoreEdit.Longitude = data.Longitude;
        regionStoreEdit.Latitude = data.Latitude;
        regionStoreEdit.SalesId = data.SalesId;
        regionStoreEdit.SalesName = data.SalesName;

        // Set selected values for dropdowns
        selectedSalesId = data.SalesId ?? "";
        selectedCityId = data.CityId ?? "";
        selectedStoreId = data.StoreId ?? "";

        var resultStore = await _storeService.GetAll();
        storeList = resultStore.ToList();

        var resultCity = await _cityService.GetAll();
        cityList = resultCity.ToList();

        var resultSales = await _salesService.GetAll();
        salesList = resultSales.ToList();

        IsEditModalOpen = true;
    }

    private async Task Update()
    {
        regionStore.Id = regionStoreEdit.Id;
        regionStore.SalesId = selectedSalesId;
        regionStore.StoreId = selectedStoreId;
        regionStore.CityId = selectedCityId;

        await _regionStoreService.Update(regionStore);
        IsEditModalOpen = false;
        regionStore = new();
        regionStoreEdit = new();
        selectedSalesId = "";
        selectedCityId = "";
        selectedStoreId = "";
        await LoadData();
    }

    private async Task ExportExcel()
    {
        var result = await _regionStoreService.GetAll();
        var fileByte = _regionStoreService.GenerateExportRegionStore(result);
        var fileBase64 = Convert.ToBase64String(fileByte);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "RegionStore.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            fileBase64
        );
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }

    private async Task GoPage()
    {
        if (currentPage >= 1 && currentPage <= totalPages)
        {
            isLoading = true;
            await LoadData();
            isLoading = false;
        }
    }
}